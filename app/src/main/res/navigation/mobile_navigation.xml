<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_dialogs">

    <fragment
        android:id="@+id/navigation_dialogs"
        android:name="com.webitel.chat.sdk.demo_android.ui.dialogs.DialogsFragment"
        android:label="@string/title_dialogs"
        tools:layout="@layout/fragment_dialogs" >
        <action
            android:id="@+id/action_navigation_dialogs_to_dialogFragment"
            app:destination="@id/dialogFragment" />
    </fragment>

    <fragment
        android:id="@+id/navigation_contacts"
        android:name="com.webitel.chat.sdk.demo_android.ui.contacts.ContactsFragment"
        android:label="@string/title_contacts"
        tools:layout="@layout/fragment_contacts" >
        <action
            android:id="@+id/action_navigation_contacts_to_dialogFragment"
            app:destination="@id/dialogFragment" />
    </fragment>
    <fragment
        android:id="@+id/dialogFragment"
        android:name="com.webitel.chat.sdk.demo_android.ui.dialog.DialogFragment"
        android:label="{dialog_title}">

        <argument
            android:name="dialog_id"
            app:argType="string"
            app:nullable="true" />

        <argument
            android:name="dialog_title"
            app:argType="string"
            app:nullable="true" />

        <argument
            android:name="contact_id"
            app:argType="string"
            app:nullable="true" />

        <argument
            android:name="contact_iss"
            app:argType="string"
            app:nullable="true" />
    </fragment>

    <fragment
        android:id="@+id/navigation_settings"
        android:name="com.webitel.chat.sdk.demo_android.ui.settings.SettingsFragment"
        android:label="@string/title_settings"
        tools:layout="@layout/fragment_settings" />
</navigation>